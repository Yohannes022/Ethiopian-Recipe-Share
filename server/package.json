{
  "name": "ethiopian-recipe-api",
  "version": "1.0.0",
  "description": "Backend API for Ethiopian Recipe Share application",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
